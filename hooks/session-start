#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# SuperStack SessionStart hook — injects the bootstrap so the loop is active from the first
# message and re-activates after /clear or compaction. Emits hook JSON with the activation
# context (Claude Code: hookSpecificOutput.additionalContext; others: additional_context).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

bootstrap="$(cat "${PLUGIN_ROOT}/skills/superstack/SKILL.md" 2>/dev/null || true)"
[ -n "$bootstrap" ] || bootstrap="Run one loop on every non-trivial task: Frame -> Plan -> Build -> Review -> QA -> Secure -> Ship -> Learn. Run /ss-help for the command index."

# Escape a string for embedding in a JSON string value (single-pass substitutions).
escape_json() {
  local s="$1"
  s="${s//\\/\\\\}"; s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"; s="${s//$'\r'/\\r}"; s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

intro="<EXTREMELY_IMPORTANT>\nSuperStack is active. Run ONE loop on every non-trivial task: Frame -> Plan -> Build -> Review -> QA -> Secure -> Ship -> Learn. Skills are mandatory workflows, not suggestions; scale the loop down for trivial changes. Below is your bootstrap skill:\n\n"
context="${intro}$(escape_json "$bootstrap")\n</EXTREMELY_IMPORTANT>"

# Front 1: append the standing-context budget advisory iff over the warn threshold (silent otherwise).
adv="$(cd "$PWD" && bash "${PLUGIN_ROOT}/scripts/ss-context" --check 2>/dev/null || true)"
[ -n "$adv" ] && context="${context}\\n\\n$(escape_json "$adv")"

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$context"
fi
exit 0
